{
  "name": "@0x-copilot/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop client for the Atlas / 0x-copilot product.",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "compile": "node esbuild.config.mjs",
    "copy:renderer-assets": "node -e \"require('node:fs').mkdirSync('out/renderer',{recursive:true}); require('node:fs').copyFileSync('renderer/index.html','out/renderer/index.html')\"",
    "build": "npm run compile",
    "dev": "npm run build && ELECTRON_RUN_AS_NODE= electron .",
    "desktop:dev": "npm run dev",
    "package": "npm run build && electron-builder --dir",
    "clean": "rm -rf out dist"
  },
  "dependencies": {
    "@0x-copilot/api-types": "0.1.0",
    "@0x-copilot/chat-surface": "0.1.0",
    "@0x-copilot/chat-transport": "0.1.0",
    "@0x-copilot/surface-renderers": "0.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "42.1.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
