{
  "name": "@0x-copilot/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "0xCopilot Electron desktop client.",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "compile": "node esbuild.config.mjs",
    "copy:renderer-assets": "node -e \"require('node:fs').mkdirSync('out/renderer',{recursive:true}); require('node:fs').copyFileSync('renderer/index.html','out/renderer/index.html')\"",
    "build": "npm run compile",
    "dev": "npm run build && ELECTRON_RUN_AS_NODE= electron .",
    "desktop:dev": "npm run dev",
    "stage:runtime": "node ../../tools/desktop-runtime/stage.mjs --platform $(node -p process.platform) --arch $(node -p process.arch)",
    "stage:runtime:mac:arm64": "node ../../tools/desktop-runtime/stage.mjs --platform darwin --arch arm64",
    "stage:runtime:mac:x64": "node ../../tools/desktop-runtime/stage.mjs --platform darwin --arch x64",
    "stage:runtime:win": "node ../../tools/desktop-runtime/stage.mjs --platform win32 --arch x64",
    "package": "npm run build && electron-builder --dir --publish never",
    "dist:mac:arm64": "npm run stage:runtime:mac:arm64 && npm run build && electron-builder --mac --arm64 --publish never",
    "dist:mac:x64": "npm run stage:runtime:mac:x64 && npm run build && electron-builder --mac --x64 --publish never",
    "dist:win": "npm run stage:runtime:win && npm run build && electron-builder --win --x64 --publish never",
    "clean": "rm -rf out dist"
  },
  "dependencies": {
    "@0x-copilot/api-types": "0.1.0",
    "@0x-copilot/chat-surface": "0.1.0",
    "@0x-copilot/chat-transport": "0.1.0",
    "@0x-copilot/design-system": "0.1.0",
    "@0x-copilot/surface-renderers": "0.1.0",
    "electron-updater": "^6.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "^2.21.55",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
