{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./out",
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["main/**/*.ts", "preload/**/*.ts"],
  "exclude": ["**/*.test.ts", "renderer/**", "out/**", "dist/**"]
}
