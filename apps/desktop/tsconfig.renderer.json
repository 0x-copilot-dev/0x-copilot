{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "types": []
  },
  "include": ["renderer/**/*.ts", "renderer/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "out/**", "dist/**"]
}
