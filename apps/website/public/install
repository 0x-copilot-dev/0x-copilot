#!/usr/bin/env bash
# 0xCopilot installer — https://0xcopilot.tech/install
#
#   curl -fsSL https://0xcopilot.tech/install | bash
#
# Installs the `copilot` CLI globally. On first run, `copilot` stages a
# self-contained local runtime and opens the desktop app. No DMG, no installer,
# no admin rights.
set -eu

PKG="@0x-copilot/cli"

say()  { printf '\033[35m0xcopilot\033[0m %s\n' "$1"; }
ok()   { printf '\033[35m0xcopilot\033[0m \033[32m✓\033[0m %s\n' "$1"; }
err()  { printf '\033[35m0xcopilot\033[0m \033[31m✗ %s\033[0m\n' "$1" >&2; }

os="$(uname -s 2>/dev/null || echo unknown)"
case "$os" in
  Darwin) ;;
  MINGW*|MSYS*|CYGWIN*) ;;                 # Git-Bash / MSYS on Windows
  *)
    err "0xCopilot desktop supports macOS and Windows (detected: $os)."
    exit 1
    ;;
esac

# Prefer bun (fast), fall back to npm.
if command -v bun >/dev/null 2>&1; then
  say "installing $PKG with bun…"
  bun add -g "$PKG"
elif command -v npm >/dev/null 2>&1; then
  say "installing $PKG with npm…"
  npm install -g "$PKG"
else
  err "you need Node.js (npm) or Bun first:"
  printf '    • Node.js  https://nodejs.org   (macOS: brew install node)\n'
  printf '    • Bun      https://bun.sh        (curl -fsSL https://bun.sh/install | bash)\n'
  exit 1
fi

if command -v copilot >/dev/null 2>&1; then
  ok "installed."
  printf '\n    Run it:  \033[1mcopilot\033[0m\n\n'
else
  err "installed, but 'copilot' is not on your PATH."
  printf "    Add your global bin dir to PATH, then run 'copilot':\n"
  printf '      export PATH="$(npm prefix -g)/bin:$PATH"\n'
  exit 1
fi
