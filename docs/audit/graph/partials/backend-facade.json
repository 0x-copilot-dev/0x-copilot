    },
    {
      "id": "backend-facade/destination-proxies",
      "kind": "route-group",
      "path": "services/backend-facade/src/backend_facade/tool_routes.py",
      "summary": "Sixteen near-identical forwarders for product destinations on backend: tools, connectors (+desktop OAuth), connector webhooks, inbox, home, library, memory, palette, projects, routines, team, todos, agents, liveness, settings — six with SSE stream proxies."
    },
    {
      "id": "backend-facade/audit-merge",
      "kind": "module",
      "path": "services/backend-facade/src/backend_facade/audit_routes.py",
      "summary": "GET /v1/audit: fans out to backend + ai-backend internal audit lists, merge-sorts by created_at with composite base64 cursor and per-stream degradation — the facade's one real aggregation."
    },
    {
      "id": "backend-facade/adapter-routes",
      "kind": "route-group",
      "path": "services/backend-facade/src/backend_facade/adapter_registry_routes.py",
      "summary": "Tier-2 adapter registry submit/promoted/opt-out plus admin review trio; the admin routes are registered by BOTH adapter_registry_routes and adapter_review_routes — the review (touch-authenticated) copies are shadowed dead code."
    },
    {
      "id": "backend-facade/local-models-proxy",
      "kind": "route-group",
      "path": "services/backend-facade/src/backend_facade/local_models_routes.py",
      "summary": "/v1/local-models proxy onto ai-backend: status/list/size/delete JSON plus SSE pull-progress stream for local Ollama models."
    },
    {
      "id": "backend-facade/webhook-ingest",
      "kind": "route-group",
      "path": "services/backend-facade/src/backend_facade/routines_webhook_routes.py",
      "summary": "POST /v1/webhook/routines/{trigger_id}: bearer-free HMAC-secret webhook proxy with byte-exact body forwarding and X-Forwarded-For chain for audit fidelity."
    },
    {
      "id": "backend-facade/wallet-page",
      "kind": "module",
      "path": "services/backend-facade/src/backend_facade/wallet_page_routes.py",
      "summary": "Env-gated static serving of the built frontend wallet.html + /assets so the packaged desktop's SIWE sign-in is same-origin with /v1/auth/siwe/* (FACADE_WEB_DIST_DIR set by the desktop supervisor)."
    },
    {
      "id": "backend-facade/http-pool",
      "kind": "module",
      "path": "services/backend-facade/src/backend_facade/http_client.py",
      "summary": "Lifespan-owned shared httpx.AsyncClient per worker (100 conns / 20 keepalive) amortizing TLS across upstream calls; http_client(app) accessor used by every route."
    },
    {
      "id": "backend-facade/settings-profile",
