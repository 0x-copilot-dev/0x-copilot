# 0xCopilot self-host configuration.
#
# install.sh generates this file for you with strong random secrets. To fill it
# by hand, copy it to .env and replace every REPLACE_ME. Never commit a real .env.
#
#   cp .env.example .env
#
# Generate a secret:  openssl rand -hex 32   (AUTH wants 64 bytes -> hex 64)

# ---- Images -----------------------------------------------------------------
# GHCR namespace + tag for the four published images. Pin IMAGE_TAG to a commit
# sha for reproducible deploys; `latest` tracks main.
GHCR_NAMESPACE=ghcr.io/0x-copilot-dev
IMAGE_TAG=latest

# ---- Ingress ----------------------------------------------------------------
# Host port the gateway publishes. Browse to http://<host>:${GATEWAY_PORT}/.
GATEWAY_PORT=8080

# ---- Secrets (REQUIRED — generate unique values per install) ----------------
# ENTERPRISE_AUTH_SECRET and ENTERPRISE_SERVICE_TOKEN MUST be byte-identical
# across backend, ai-backend, and facade (they sign/verify the same bearers and
# service-to-service lane). Rotating them invalidates every session.
ENTERPRISE_AUTH_SECRET=REPLACE_ME        # openssl rand -hex 64
ENTERPRISE_SERVICE_TOKEN=REPLACE_ME      # openssl rand -hex 32
MCP_TOKEN_VAULT_SECRET=REPLACE_ME        # openssl rand -hex 32 (>= 32 chars)
AUDIT_HMAC_KEY=REPLACE_ME                # openssl rand -hex 32 (hex, >= 32 bytes)

# ---- Postgres ---------------------------------------------------------------
# One Postgres instance holds two logical databases: atlas_backend + atlas_ai.
# Use a URL-safe password (hex). Changing it after first boot orphans the volume.
POSTGRES_USER=atlas
POSTGRES_PASSWORD=REPLACE_ME             # openssl rand -hex 24

# ---- Wallet login (SIWE) ----------------------------------------------------
# SIWE_ORIGIN MUST equal the exact public origin the browser loads from
# (scheme + host + port, no trailing slash). Behind TLS/a domain, set it to that.
SIWE_ORIGIN=http://localhost:8080
# Comma-separated chain ids allowed for wallet sign-in.
# Default: 1 (Ethereum), 8453 (Base), 42161 (Arbitrum), 4663.
SIWE_ALLOWED_CHAIN_IDS=1,8453,42161,4663

# ---- Google login (OPTIONAL) ------------------------------------------------
# Leave blank to hide "Continue with Google". Set both to enable it. Register the
# redirect URI ${SIWE_ORIGIN}/v1/auth/oidc/google/callback in Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Model provider keys (OPTIONAL) -----------------------------------------
# BYOK: users add their own keys in Settings. Set a shared fallback only if you
# want the instance to work before anyone adds a personal key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- Tuning (OPTIONAL) ------------------------------------------------------
# gunicorn workers for the ai-backend API. 2 is fine for a small box.
AI_BACKEND_WORKERS=2
