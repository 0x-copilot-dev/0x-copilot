OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

RUNTIME_ENVIRONMENT=development
RUNTIME_DEFAULT_PROVIDER=openai
RUNTIME_DEFAULT_MODEL=gpt-5.4-mini
RUNTIME_DEFAULT_TEMPERATURE=0
RUNTIME_DEFAULT_TIMEOUT_SECONDS=180
RUNTIME_DEFAULT_MAX_INPUT_TOKENS=128000
RUNTIME_DEFAULT_SUPPORTS_STREAMING=true
RUNTIME_PRESENTATION_MODEL=gpt-4.1-nano
RUNTIME_PRESENTATION_TIMEOUT_SECONDS=1.5
RUNTIME_MAX_RETRIES=2
RUNTIME_MAX_PARALLEL_RUNS=4
RUNTIME_MAX_PARALLEL_TASKS=4
RUNTIME_MAX_PARALLEL_SUBAGENTS=4
RUNTIME_TOOL_CALL_BUDGET=6
RUNTIME_ALLOW_EMPTY_CAPABILITIES=false
ENTERPRISE_SERVICE_TOKEN=
