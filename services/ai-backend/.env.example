OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

RUNTIME_ENVIRONMENT=development
RUNTIME_DEFAULT_PROVIDER=openai
RUNTIME_DEFAULT_MODEL=gpt-5.4-mini
RUNTIME_DEFAULT_TEMPERATURE=0
RUNTIME_DEFAULT_TIMEOUT_SECONDS=180
RUNTIME_DEFAULT_MAX_INPUT_TOKENS=128000
RUNTIME_DEFAULT_SUPPORTS_STREAMING=true
RUNTIME_MAX_RETRIES=2
RUNTIME_MAX_PARALLEL_RUNS=4
RUNTIME_MAX_PARALLEL_TASKS=4
RUNTIME_MAX_PARALLEL_SUBAGENTS=4
RUNTIME_TOOL_CALL_BUDGET=6
RUNTIME_ALLOW_EMPTY_CAPABILITIES=false
ENTERPRISE_SERVICE_TOKEN=

# --- Event pipeline / SSE bus (P2 + P4) ---------------------------------------
# P4 Stage 1 — fold append_event INSERT + agent_runs.latest_sequence_no
# UPDATE into one transaction. Default on; flip to false for full
# rollback to the pre-P4 two-transaction path.
RUNTIME_EVENT_WRITE_CONSOLIDATED=true
# P4 Stage 2 — worker-side MODEL_DELTA coalesce window (ms). 0 disables
# coalescing and matches pre-Stage-2 behavior (one DB round-trip per
# chunk). Recommended 50 once measured on staging — chunks within the
# window flush as one batched INSERT.
RUNTIME_DELTA_COALESCE_WINDOW_MS=0
RUNTIME_DELTA_COALESCE_MAX_CHUNKS=64
# P2 — SSE event-bus backend.
#   in_memory (default) — single-process asyncio.Condition pub/sub. Works
#     when API and worker share a process (RUNTIME_START_IN_PROCESS_WORKER
#     =true) or in single-replica deploys. SSE delivery falls back to a
#     2s poll cross-process.
#   postgres — cross-process LISTEN/NOTIFY. Worker NOTIFYs after every
#     append; API process holds a dedicated LISTEN connection. Drops SSE
#     delivery latency from ~1s (poll fallback) to ~50ms in multi-process
#     deploys. Requires DATABASE_URL configured.
RUNTIME_EVENT_BUS_BACKEND=in_memory

# --- Reasoning / extended thinking (PR 3.6) -----------------------------------
# Off by default: when every var below is unset, `ModelConfig.reasoning` is
# None and no `thinking` / `reasoning` kwarg is sent to the provider SDK.
# Set any one of them (or just `RUNTIME_DEFAULT_REASONING_ENABLED=true`) to
# flip the gate. Per-run overrides from the FE model picker still win.
#
#   - OpenAI Responses (o-family / gpt-5 family): builds `reasoning={effort, summary}`.
#     `summary` MUST be set ("auto"/"concise"/"detailed") for the SDK to
#     return reasoning summary text — without it you get token counts only.
#   - Anthropic (Sonnet 4.x / Opus 4.x): builds `thinking={type, budget_tokens}`.
#   - Gemini: not surfaced today.
#
# The model still has to support reasoning. `gpt-4o-mini`, `claude-3.5-sonnet`,
# `gemini-2.5-pro` (no thinking) ignore these kwargs.
# RUNTIME_DEFAULT_REASONING_ENABLED=true
# RUNTIME_DEFAULT_REASONING_EFFORT=medium         # minimal | low | medium | high | xhigh
# RUNTIME_DEFAULT_REASONING_SUMMARY=auto          # OpenAI only — required for visible text
# RUNTIME_DEFAULT_REASONING_BUDGET_TOKENS=4000    # Anthropic — budget for one think span
# RUNTIME_DEFAULT_THINKING_MODE=enabled           # Anthropic — enabled | adaptive
