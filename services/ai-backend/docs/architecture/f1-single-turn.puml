@startuml f1-single-turn
title Flow 1 — Single-turn message (no tools)

!theme plain
skinparam shadowing false
skinparam ArrowColor #5B6770
skinparam sequenceMessageAlign center

actor "User\n(browser)" as u
participant "backend-facade" as facade
participant "RuntimeApiRoutes\n(http/routes.py)" as r
participant "RuntimeApiService\n(agent_runtime/api/service.py)" as svc
participant "Persistence + Queue\n(adapters)" as q
participant "RuntimeWorker\n(loop.py)" as wkr
participant "RuntimeRunHandler\n(handlers/run.py)" as h
participant "StreamingExecutor\n(streaming_executor.py)" as exec
participant "create_agent_runtime\n(execution/factory.py)" as core
participant "LLM provider\n(Anthropic / OpenAI / Gemini)" as llm
participant "RuntimeEventProducer\n(api/events.py)" as ep
participant "EventStore" as es
participant "RuntimeEventBus" as bus
participant "RuntimeSseAdapter\n(sse/adapter.py)" as sse

u -> facade : POST /v1/agent/runs\n{message, model_profile, …}
facade -> r : same (forwarded;\nidentity headers added)

r -> svc : create_run(CreateRunRequest)
svc -> q : persistence.create_run(),\npersistence.create_message(user),\nqueue.enqueue(RuntimeRunCommand)
svc --> r : RunRecord(run_id, status=QUEUED)
r --> facade : 202 Accepted +\n{run_id, conversation_id}
facade --> u : 202 Accepted

u -> facade : GET /v1/agent/runs/{run_id}/stream\n?after_sequence=0&follow=true
facade -> r : same
r -> sse : RuntimeSseAdapter.stream(...)

== Worker picks up the queued run ==

wkr -> q : queue.claim_next(worker_id,\nlock_expires_at)
q --> wkr : RuntimeWorkerClaim\n(command_type=RUN_REQUESTED)
wkr -> h : run_handler.handle(command)
h -> ep : append_api_event(RUN_STARTED)\n→ sequence_no=1
ep -> es : event_store.append_event
es --> ep : envelope.sequence_no=1
ep -> q : set_run_latest_sequence(1)
ep ->> bus : on_event_appended(run_id)

bus -->> sse : wake from wait()
sse -> svc : replay_events(after_sequence=0)
svc --> sse : [envelope#1]
sse -->> u : event: runtime_event\nid: 1\ndata: {…RUN_STARTED…}

h -> exec : run(stream, run, metrics, …)
exec -> core : create_agent_runtime(context, deps)
core --> exec : runtime harness\n(LangGraph compiled)
exec -> llm : astream(messages)\n(provider stream adapter)

loop streaming chunks
  llm -->> exec : chunk (text delta)
  exec -> ep : append_api_event(MODEL_DELTA)
  ep -> es : append → sequence_no++
  ep ->> bus : notify(run_id)
  bus -->> sse : wake
  sse -> svc : replay_events(after_sequence=N)
  svc --> sse : [envelope#N+1]
  sse -->> u : SSE frame (id: N+1)
end

llm -->> exec : final aggregated message
exec -> ep : append_api_event(FINAL_RESPONSE)
ep -> es : sequence_no++
exec -> ep : append_api_event(RUN_COMPLETED)
ep -> es : sequence_no++
ep ->> bus : notify(run_id)
sse -> svc : replay_events(...)
sse -->> u : final SSE frames

note over sse, u
  replay returns run_status=COMPLETED →
  TERMINAL_RUN_STATUSES → adapter
  unsubscribes from bus and returns;
  the SSE stream closes naturally.
end note

h -> q : queue.mark_complete(claim)

@enduml
