@startuml f4-cancel
title Flow 4 — Run cancellation

!theme plain
skinparam shadowing false
skinparam ArrowColor #5B6770
skinparam sequenceMessageAlign center

actor "User" as u
participant "backend-facade" as facade
participant "RuntimeApiRoutes" as r
participant "RuntimeApiService\n.cancel_run()" as svc
participant "Persistence + Queue" as q
participant "Run handler\n(streaming the active run)" as h_run
participant "RuntimeWorker\n(claim loop)" as wkr
participant "RuntimeCancelHandler" as h_cancel
participant "RuntimeEventProducer" as ep
participant "EventStore" as es
participant "RuntimeEventBus + SSE" as sse

note over h_run, sse
  Pre-condition: a run is RUNNING with
  a streaming model call in flight; user
  is connected via SSE seeing MODEL_DELTAs.
end note

== Cancel request ==

u -> facade : POST /v1/agent/runs/{run_id}/cancel
facade -> r : same
r -> svc : cancel_run(org_id, user_id, run_id)
svc -> q : queue.enqueue(\n   RuntimeCancelCommand,\n   command_type=RUN_CANCEL_REQUESTED)
svc -> ep : append_api_event(RUN_CANCELLING)\n(advisory only)
ep -> es : sequence_no++
ep ->> sse : notify
svc --> r : 202 Accepted
r --> u : 202 Accepted (cancel queued)

== Worker observes cancel command ==

wkr -> q : queue.claim_next()
q --> wkr : RuntimeWorkerClaim\n(command_type=RUN_CANCEL_REQUESTED)
wkr -> h_cancel : handle(RuntimeCancelCommand)

h_cancel -> q : persistence.update_run_status(\n   run_id, status=CANCELLED)
h_cancel -> ep : append_api_event(RUN_CANCELLED)
ep -> es : sequence_no++
ep ->> sse : notify

note over h_run
  The active run handler is iterating the
  LangGraph stream cooperatively. A pending
  model chunk in flight may still arrive
  and emit one more MODEL_DELTA before the
  loop checks run status; this is acceptable —
  CANCELLED is the terminal state of record.
end note

h_run -> q : (next loop tick) check run status
q --> h_run : status=CANCELLED → exit loop
h_run -> q : queue.mark_complete(\n   original RUN_REQUESTED claim)

== SSE clients see terminal status ==

sse -> svc : replay_events(after_sequence=N)
svc --> sse : [...,\n  RUN_CANCELLING,\n  RUN_CANCELLED]\nrun_status=CANCELLED
sse -->> u : SSE frames
sse -> sse : run_status in TERMINAL_RUN_STATUSES\n→ unsubscribe(run_id), return
sse -->> u : (stream closes)

h_cancel -> q : queue.mark_complete(cancel claim)

note over wkr, h_cancel
  RuntimeWorker._dispatch handles three
  command_type values:
   • RUN_REQUESTED      → RuntimeRunHandler
   • RUN_CANCEL_REQUESTED → RuntimeCancelHandler
   • APPROVAL_RESOLVED  → RuntimeApprovalHandler
  Anything else raises VALIDATION_ERROR.
end note

@enduml
