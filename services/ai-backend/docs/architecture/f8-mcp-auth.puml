@startuml f8-mcp-auth
title Flow 8 — Calling an unauthenticated MCP tool, authenticating in-chat

!theme plain
skinparam shadowing false
skinparam ArrowColor #5B6770
skinparam sequenceMessageAlign center

actor "User" as u
participant "Frontend\n(chat UI)" as fe
participant "RuntimeApiRoutes\n+ Service" as svc
participant "RuntimeWorker\n+ StreamingExecutor" as exec
participant "Deep Agents graph" as graph
participant "LLM provider" as llm
participant "CallMcpTool +\nMcpPermissionPolicy" as call_mw
participant "AuthMcpTool +\nMcpAuthSessionCreator\n(mcp/middleware/auth_mcp.py)" as auth_mw
participant "backend\n(/internal/v1/mcp/.../auth/start,\n token vault, OAuth callback)" as backend
participant "MCP server\n(3rd-party OAuth IdP)" as mcp_idp
participant "RuntimeEventProducer\n+ EventStore" as ep
participant "Persistence\n(approval row)" as p
participant "RuntimeApprovalHandler" as h_appr

note over u, h_appr
  Pre-condition: a server is *installed* (flow 7) but its
  auth_state is NONE or EXPIRED. The model selects a tool
  on it during a normal turn. The streaming executor
  short-circuits on MCP_AUTH_REQUIRED (it is one of
  StreamingExecutor.action_interrupt_events).
end note

== Run starts — model picks an unauthed tool ==

u -> fe : "find my recent Linear tickets"
fe -> svc : POST /v1/agent/runs
svc -> exec : (worker claims, run starts)
exec -> graph : drive stream
graph -> llm : invoke with tools
llm -->> graph : tool_call(linear_search, args)
graph -> call_mw : call_tool(linear_search)

== Permission policy denies on auth_state ==

call_mw -> call_mw : McpPermissionPolicy.\nis_tool_authorized?\n→ auth_state=NONE
call_mw -> auth_mw : route through AuthMcpTool

auth_mw -> backend : POST /internal/v1/mcp/servers/\n  {server_id}/auth/start\n(create McpAuthSession)
backend --> auth_mw : McpAuthSession\n{auth_url, session_id}

auth_mw -> p : insert approval row\n(kind=mcp_auth,\n status=PENDING,\n payload={server_id,\n   auth_url, session_id})
auth_mw -> ep : append_api_event(\n  MCP_AUTH_REQUIRED,\n  payload includes auth_url +\n  safe message; visibility=USER,\n  activity_kind=mcp_auth,\n  presentation.kind=auth)
ep -> ep : sequence_no++
ep ->> svc : on_event_appended\n(notify_sync)

note right of exec
  StreamingExecutor sees event_type ==
  MCP_AUTH_REQUIRED in
  action_interrupt_events → ends the
  stream loop with action_interrupted=True.
  Run is paused; queue.mark_complete is
  NOT called yet (the resume flow does it).
end note

exec -> svc : transition run to status=AWAITING_APPROVAL
svc --> u : (SSE) inline auth card\n"Connect Linear to continue"

== User authenticates in a popup ==

u -> fe : click "Connect"
fe -> backend : open auth_url\n(separate window/tab)
backend -> mcp_idp : OAuth authorize redirect
mcp_idp -> u : login + consent
u -> mcp_idp : approve
mcp_idp -> backend : OAuth callback\n(authorization_code)
backend -> mcp_idp : exchange code → access_token,\n refresh_token
mcp_idp --> backend : tokens
backend -> backend : TokenVault.put(server_id,\n encrypted tokens)
backend -> backend : update ServerRecord\n auth_state=VALID
backend --> fe : success page\n(window closes)

== Frontend resumes the run ==

fe -> svc : POST /v1/approvals/{approval_id}/decision\n{decision=APPROVE}
svc -> p : update approval row\n status=APPROVED
svc -> ep : append_api_event(APPROVAL_RESOLVED)
svc -> svc : queue.enqueue(\n  RuntimeApprovalResolvedCommand,\n  command_type=APPROVAL_RESOLVED)
svc --> fe : 202 Accepted

== Worker resumes via ApprovalHandler ==

h_appr -> svc : queue.claim_next →\nApprovalResolvedCommand
h_appr -> p : load run + approval row
h_appr -> exec : re-run StreamingExecutor with\nresumed graph state
exec -> graph : continue stream
graph -> llm : (LLM either retries\n  the tool call or is told\n  "auth is now valid")
llm -->> graph : tool_call(linear_search)
graph -> call_mw : call_tool again
call_mw -> call_mw : McpPermissionPolicy →\nauth_state=VALID ✓
call_mw -> backend : RPC call_tool
backend -> mcp_idp : authenticated request
mcp_idp --> backend : tickets
backend --> call_mw : tool result
exec -> ep : TOOL_CALL + TOOL_RESULT
exec -> ep : MODEL_DELTA → FINAL_RESPONSE → RUN_COMPLETED
ep ->> svc : notifies SSE
svc -->> u : answer with citations

note over auth_mw, backend
  Token rotation + expiry are owned by the backend's
  token vault, not ai-backend. When tokens expire mid-
  run, the same MCP_AUTH_REQUIRED → APPROVAL_RESOLVED
  loop fires again. The approval row is the durable
  rendezvous between the user's click and the worker's
  resume — surviving worker restarts and SSE drops.
end note

@enduml
