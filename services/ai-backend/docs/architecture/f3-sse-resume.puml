@startuml f3-sse-resume
title Flow 3 — SSE resume after disconnect

!theme plain
skinparam shadowing false
skinparam ArrowColor #5B6770
skinparam sequenceMessageAlign center

actor "User\n(browser)" as u
participant "backend-facade" as facade
participant "RuntimeApiRoutes" as r
participant "RuntimeSseAdapter\n(sse/adapter.py)" as sse
participant "RuntimeApiService\n.replay_events(...)" as svc
participant "EventStore\n(adapter)" as es
participant "RuntimeEventBus" as bus
participant "Worker (background)" as wkr

note over u, wkr
  Pre-condition: a run is in progress and
  the client has already received events up
  to sequence_no=42. Network blip drops the
  open SSE connection.
end note

== Reconnection ==

u -> facade : GET /v1/agent/runs/{id}/stream\n?after_sequence=42&follow=true
facade -> r : same
r -> sse : RuntimeSseAdapter.stream(\n   service, org_id, user_id,\n   run_id, after_sequence=42,\n   follow=true,\n   event_bus=runtime_event_bus)

== Initial replay (gap fill) ==

sse -> svc : replay_events(after_sequence=42)
svc -> es : list_events_after(run_id, 42)
es --> svc : [envelope#43, #44, #45]
svc --> sse : RuntimeEventReplayResponse(\n   events,\n   latest_sequence_no=45,\n   run_status=RUNNING)

loop for each replayed event
  sse -> sse : latest_sequence = max(latest, e.sequence_no)
  sse -->> u : event: runtime_event\nid: <seq>\ndata: <json>
end

note right of sse
  run_status not in TERMINAL_RUN_STATUSES,
  follow=true → enter the wait loop.
end note

== Steady-state tailing ==

loop until terminal status
  sse -> bus : await wait(run_id,\ntimeout=FALLBACK_POLL_SECONDS=2.0)

  alt push notification arrives
    wkr ->> bus : notify_sync(run_id)\n(after appending event)
    bus -->> sse : wake
  else timeout (no events for 2s)
    bus -->> sse : timeout
  end

  sse -> svc : replay_events(after_sequence=latest)
  svc --> sse : new envelopes (or empty)
  loop yield deltas
    sse -->> u : SSE frame (id: <seq>)
  end
end

== Terminal status ==

wkr ->> bus : notify(run_id) — RUN_COMPLETED appended
bus -->> sse : wake
sse -> svc : replay_events(...)
svc --> sse : envelope#N (RUN_COMPLETED),\nrun_status=COMPLETED
sse -->> u : SSE frame
sse -> bus : event_bus.unsubscribe(run_id)
sse -->> u : (close stream)

note over sse, u
  follow=false path: yields a synthetic HEARTBEAT
  envelope (sequence_no = max(1, latest+1),
  metadata.transient=true) when no new events
  exist, then closes — that variant lets clients
  poll for snapshots without a live tail.
end note

@enduml
