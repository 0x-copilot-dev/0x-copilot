OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

RUNTIME_ENVIRONMENT=development
RUNTIME_DEFAULT_PROVIDER=openai
RUNTIME_DEFAULT_MODEL=gpt-5.4-mini
RUNTIME_DEFAULT_TEMPERATURE=0
RUNTIME_DEFAULT_TIMEOUT_SECONDS=180
RUNTIME_DEFAULT_MAX_INPUT_TOKENS=128000
RUNTIME_DEFAULT_SUPPORTS_STREAMING=true
RUNTIME_DEFAULT_REASONING_ENABLED=true
RUNTIME_DEFAULT_REASONING_EFFORT=medium
RUNTIME_DEFAULT_REASONING_SUMMARY=auto
RUNTIME_DEFAULT_REASONING_DISPLAY=
RUNTIME_DEFAULT_REASONING_BUDGET_TOKENS=
RUNTIME_DEFAULT_REASONING_INCLUDE_ENCRYPTED_CONTENT=
RUNTIME_DEFAULT_THINKING_MODE=
RUNTIME_PRESENTATION_MODEL=gpt-4.1-nano
RUNTIME_PRESENTATION_TIMEOUT_SECONDS=1.5
RUNTIME_MAX_RETRIES=2
RUNTIME_MAX_PARALLEL_RUNS=4
RUNTIME_MAX_PARALLEL_SUBAGENTS=4
RUNTIME_TOOL_CALL_BUDGET=6
RUNTIME_STORE_BACKEND=in_memory
DATABASE_URL=
RUNTIME_WORKER_POLL_INTERVAL_SECONDS=1
RUNTIME_WORKER_LOCK_SECONDS=60
RUNTIME_START_IN_PROCESS_WORKER=true
RUNTIME_ALLOW_EMPTY_CAPABILITIES=false
# P4 Stage 1 — fold append_event INSERT + agent_runs.latest_sequence_no
# UPDATE into one transaction (default on; flip to false to roll back to
# the pre-P4 two-transaction path).
RUNTIME_EVENT_WRITE_CONSOLIDATED=true
# P4 Stage 2 — worker-side MODEL_DELTA coalesce window (ms). 0 = disabled
# (default; ships dark). Recommended 50 once measured on staging.
RUNTIME_DELTA_COALESCE_WINDOW_MS=0
RUNTIME_DELTA_COALESCE_MAX_CHUNKS=64
# P2 — SSE event-bus backend. Default is ``auto`` (resolves to ``postgres``
# when DATABASE_URL is configured, else ``in_memory``). Dev pins
# ``in_memory`` here because dev typically runs API + worker in one
# process (RUNTIME_START_IN_PROCESS_WORKER=true) and DATABASE_URL may
# point at Postgres without us wanting LISTEN/NOTIFY overhead. Prod
# leaves this unset → ``auto`` → ``postgres`` once DATABASE_URL is
# present (drops SSE delivery latency from ~1s to ~50ms).
RUNTIME_EVENT_BUS_BACKEND=in_memory
# P7 PR2 — switch the citation projector to one batched
# `sources_ingested` event per tool result (vs. N `source_ingested`
# events under the legacy per-source loop). Default false (PR2 ships
# dark); flip to true on workers after staging validation. Behavior is
# wire-equivalent for the FE — both event types are handled by the
# citation reducers.
RUNTIME_BATCH_SOURCE_INGESTION=false
# --- Local models (Ollama) — off by default, one uncomment away -------------
# Uncomment to expose /v1/local-models/* in `make dev`: Settings -> Local
# models plus the first-run "Download the local model" card become live (pull
# an HF GGUF and run it through a user-installed Ollama). Left off, /status
# reports enabled:false and every other local-models route 404s, so none of
# the first-run local-model states can be exercised outside a staged desktop
# boot. Requires Ollama on this machine: https://ollama.com/download
# RUNTIME_ENABLE_LOCAL_MODELS=true
# Additionally authorises this server to detect the Ollama binary on THIS
# machine and start it (POST /v1/local-models/runtime/start). Uncomment only
# when ai-backend runs natively on your own machine (`make dev`) — that is
# what makes the card's "Ollama not installed" vs "Ollama stopped responding"
# states and the Restart Ollama action reachable in dev. Leave it off for any
# containerised run (`make docker-dev`, self-host): a container cannot see the
# host's binary, so the honest answer there is runtime_state "unknown".
# RUNTIME_LOCAL_MODELS_MANAGE_RUNTIME=true
# OpenAI-compatible Ollama endpoint. Default http://localhost:11434/v1, which
# is what you want for a native `make dev`; override only to point at a
# non-default host/port. NOTE — unlike every other key in this file, this one
# is NOT read through RuntimeSettings: OpenAICompatibleEndpoint.resolve_base_url
# reads os.environ directly, so a value here (or in .env) is silently ignored.
# Export it into the process environment instead:
#   OLLAMA_BASE_URL=http://127.0.0.1:11500/v1 make dev
# Container stacks already set it explicitly (docker-compose.dev.yml,
# deploy/self-host/docker-compose.prod.yml).
MCP_BACKEND_REGISTRY_URL=
MCP_AUTH_REDIRECT_URI=http://127.0.0.1:5173/mcp/oauth/callback
SKILLS_BACKEND_REGISTRY_URL=
SKILLS_CACHE_TTL_SECONDS=60
