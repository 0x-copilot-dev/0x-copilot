    "document",
    "fetch",
    "XMLHttpRequest",
    "WebSocket",
    "EventSource",
    "localStorage",
    "sessionStorage",
    "navigator",
    "history",
    "location",
    "crypto",
    "process",
    "global",
    "globalThis",
    "child_process",
    "fs",
    "net",
    "http",
    "https",
    "path",
    "os",
    "Buffer",
    "setImmediate",
    "clearImmediate",
    "require"
