{
  "schema_version": 1,
  "allowed_imports": {
    "react": ["createElement", "Fragment", "useState"],
    "react-dom": [],
    "@0x-copilot/design-system": [
      "Button",
      "Badge",
      "Card",
      "TextInput",
      "Select",
      "Switch",
      "Toggle",
      "Field",
      "IconButton",
      "StatusPill",
      "AppIcon",
      "HarnessRow",
      "StatusLine",
      "ConnectorChip",
      "classNames"
    ]
